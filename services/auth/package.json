{
  "name": "auth",
  "version": "0.34.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "cross-env NODE_ENV=production nest start",
    "start:prod": "node dist/main",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "cross-env NODE_ENV=test vitest --config vitest.config.ts",
    "test:e2e": "sh ./tests-e2e.sh",
    "test:e2e:cov": "sh ./tests-e2e.sh --cov",
    "test:cov": "cross-env NODE_ENV=test vitest --coverage --config vitest.config.ts",
    "test:unit": "cross-env NODE_ENV=test vitest --config vitest.config.unit.ts",
    "test:unit:cov": "cross-env NODE_ENV=test vitest --coverage --config vitest.config.unit.ts",
    "jwt:keys:auth": "openssl genrsa -out ./certs/auth-private.pem 2048 && openssl rsa -in ./certs/auth-private.pem -pubout -out ./certs/auth-public.pem",
    "jwt:keys:reset-pass": "openssl genrsa -out ./certs/reset-pass-private.pem 2048 && openssl rsa -in ./certs/reset-pass-private.pem -pubout -out ./certs/reset-pass-public.pem",
    "jwt:keys:generate": "bun run jwt:keys:auth && bun run jwt:keys:reset-pass",
    "jwt:keys:clean": "rm ./certs/*.pem",
    "mtls:ca": "openssl genrsa -out ./certs/ca-key.pem 4096 && openssl req -new -x509 -days 365 -key ./certs/ca-key.pem -out ./certs/ca-cert.pem -subj '/C=BR/ST=SP/L=SaoPaulo/O=MyCompany/OU=IT/CN=MyCA'",
    "mtls:server": "openssl genrsa -out ./certs/server-key.pem 4096 && openssl req -new -key ./certs/server-key.pem -out ./certs/server-csr.pem -subj '/C=BR/ST=SP/L=SaoPaulo/O=MyCompany/OU=IT/CN=localhost' && echo 'subjectAltName = DNS:localhost,DNS:*.localhost,IP:127.0.0.1\nextendedKeyUsage = serverAuth' > ./certs/server-ext.cnf && openssl x509 -req -days 365 -in ./certs/server-csr.pem -CA ./certs/ca-cert.pem -CAkey ./certs/ca-key.pem -CAcreateserial -out ./certs/server-cert.pem -extfile ./certs/server-ext.cnf",
    "mtls:client": "openssl genrsa -out ./certs/client-key.pem 4096 && openssl req -new -key ./certs/client-key.pem -out ./certs/client-csr.pem -subj '/C=BR/ST=SP/L=SaoPaulo/O=MyCompany/OU=IT/CN=client' && echo 'extendedKeyUsage = clientAuth' > ./certs/client-ext.cnf && openssl x509 -req -days 365 -in ./certs/client-csr.pem -CA ./certs/ca-cert.pem -CAkey ./certs/ca-key.pem -CAcreateserial -out ./certs/client-cert.pem -extfile ./certs/client-ext.cnf",
    "mtls:generate": "bun run mtls:ca && bun run mtls:server && bun run mtls:client && rm -f ./certs/*.csr ./certs/*.cnf ./certs/*.srl && chmod 400 ./certs/ca-key.pem && chmod 600 ./certs/*-key.pem && chmod 644 ./certs/*-cert.pem",
    "mtls:clean": "rm -f ./certs/ca-*.pem ./certs/server-*.pem ./certs/client-*.pem"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.0",
    "@fastify/static": "^9.0.0",
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/common": "^11.1.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.12",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.12",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.12",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/terminus": "^11.0.0",
    "amqp-connection-manager": "^4.1.15",
    "amqplib": "^0.10.9",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "fastify": "^5.7.1",
    "handlebars": "^4.7.8",
    "ioredis": "^5.9.0",
    "jose": "^6.1.3",
    "mongoose": "^9.1.4",
    "nodemailer": "^7.0.12",
    "openssl-nodejs": "^1.0.5",
    "opossum": "^9.0.0",
    "otp-generator": "^4.0.1",
    "p-limit": "^7.3.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "supertest": "^7.2.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^11.1.12",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.27",
    "@types/nodemailer": "^7.0.4",
    "@types/opossum": "^8.1.9",
    "@types/otp-generator": "^4.0.2",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitest/coverage-istanbul": "^4.0.18",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.4",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "vitest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-vitest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "overrides": {
    "fastify": "5.7.1",
    "glob@>=10.2.0 <10.5.0": ">=10.5.0",
    "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
    "nodemailer@<7.0.11": ">=7.0.11",
    "nodemailer@<7.0.7": ">=7.0.7",
    "nodemailer@<=7.0.10": ">=7.0.11",
    "qs@<6.14.1": ">=6.14.1",
    "tmp@<=0.2.3": ">=0.2.4"
  }
}
